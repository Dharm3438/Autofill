MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/solar_docs?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE_HOURS=24

# Brevo transactional email (HTTP API over HTTPS - works on hosts that block SMTP)
# Create key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
# FROM_EMAIL must be a verified sender in Brevo (Senders & IPs > Senders).
# A single email can be verified without owning a domain.
FROM_EMAIL=your_verified_sender@gmail.com
FROM_NAME=Solar Docs Platform

FRONTEND_URL=http://localhost:5173

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=solar-docs
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
